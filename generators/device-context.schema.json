{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "device-context.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "string",
      "oneOf": [{ "const": "desktop" }, { "const": "mobile" }, { "const": "tablet" }]
    },
    "width": {
      "$ref": "./common.schema.json#/$defs/width"
    },
    "height": {
      "$ref": "./common.schema.json#/$defs/height"
    }
  },
  "required": ["format"]
}
