{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "device-breakpoints.schema.json",
  "$defs": {
    "width": {
      "type": "integer",
      "oneOf": [
        { "const": 1385 },
        { "const": 1280 },
        { "const": 1100 },
        { "const": 768 },
        { "const": 601 },
        { "const": 430 },
        { "const": 360 }
      ]
    },
    "height": {
      "type": "integer",
      "oneOf": [{ "const": 1000 }, { "const": 750 }, { "const": 500 }]
    }
  }
}
