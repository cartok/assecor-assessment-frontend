{
  "name": "swapi-angular-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "lint": "bun run lint:tsc && bun run lint:ng && prettier --check . || true",
    "lint:tsc": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json",
    "lint:ng": "ng lint",
    "fix": "bun run lint:tsc && bun run lint:ng --fix && bun run format",
    "format": "prettier --write --list-different ."
  },
  "private": true,
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.1.5",
    "@angular/ssr": "21.2.0",
    "@elysiajs/static": "^1.4.7",
    "elysia": "^1.4.27",
    "express": "^5.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.5",
    "@csstools/postcss-global-data": "^4.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "postcss-custom-media": "^12.0.1",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "quicktype": "^23.2.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "^4.0.8"
  }
}
