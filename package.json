{
  "name": "swapi-angular-frontend",
  "version": "0.0.0",
  "scripts": {
    "generate:device-cookie:types": "mkdir -p generated/types && quicktype --src generators/device-cookie.schema.json --src-lang schema --lang typescript -o generated/types/device-cookie.types.ts --nice-property-names --readonly --top-level DeviceCookie --just-types",
    "generate:device-cookie:validator": "tsx generators/device-cookie.validator.generator.mts",
    "generate:postcss-media-tokens": "tsx generators/postcss-media-tokens.generator.mts",
    "generate": "bun run generate:device-cookie:types && bun run generate:device-cookie:validator && bun run generate:postcss-media-tokens",
    "prebuild": "bun run generate",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "lint": "bun run lint:tsc && bun run lint:ng && prettier --check . || true",
    "lint:tsc": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json",
    "lint:ng": "ng lint",
    "fix": "bun run lint:tsc && bun run lint:ng --fix && bun run format",
    "format": "prettier --write --list-different ."
  },
  "private": true,
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-server": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@angular/ssr": "21.2.0",
    "@sinclair/typebox": "^0.34.48",
    "@types/cookie-parser": "^1.4.10",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "rxjs": "~7.8.2",
    "structured-headers": "^2.0.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@csstools/postcss-global-data": "^4.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "ajv": "^8.18.0",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.8",
    "postcss-custom-media": "^12.0.1",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "quicktype": "^23.2.6",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "^4.0.18",
    "ya-json-schema-types": "^1.0.1"
  }
}
