{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/server",
    "types": ["node"],
    "allowJs": true
  },
  "include": [
    "src/server.ts",
    "src/server/**/*.ts",
    "src/main.server.ts",
    "src/app/app.config.server.ts",
    "src/app/app.routes.server.ts",
    "generated/**/*.ts",
    "generated/**/*.mts",
    "generated/**/*.mjs"
  ]
}
